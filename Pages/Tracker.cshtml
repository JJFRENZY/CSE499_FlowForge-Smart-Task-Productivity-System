@page
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var requestToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}
<meta name="csrf-token" content="@requestToken" />

@model TrackerModel

@{
    ViewData["Title"] = "Task Dashboard";
}

<link rel="stylesheet" href="~/css/tracker.css" />
<script src="~/js/weekPicker.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<header>
    <div>
        <h1>📊 Task Dashboard</h1>
        <p>Your personal task hub</p>
    </div>

    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
        <button type="submit">🚪 Logout</button>
    </form>
</header>

<main>
    <div class="task-container">
        <h2>✏️ Manage Tasks</h2>

        <div class="task-form">
            <input type="text" id="taskInput" placeholder="Write a new task..." />

            <select id="prioritySelect">
                <option value="low">Low Priority</option>
                <option value="medium">Medium Priority</option>
                <option value="high">High Priority</option>
            </select>

            <select id="categorySelect">
                <option value="school">🏫 School</option>
                <option value="work">💼 Work</option>
                <option value="other">📌 Other</option>
            </select>


            <input type="date" id="dueDateInput" />

            <button type="button" id="addTaskBtn">➕ Add Task</button>
        </div>

        <ul id="taskList">
            @foreach (var task in Model.Tasks)
            {
                var isOverdue = !task.IsCompleted && task.DueDate.HasValue && task.DueDate.Value.Date < DateTime.Today;
                var isDueToday = task.DueDate.HasValue && task.DueDate.Value.Date == DateTime.Today;
                var priorityText = task.Priority == "high" ? "HIGH" : task.Priority == "medium" ? "MED" : "LOW";
                var categoryText = task.Category switch
                {
                    "school" => "🏫 School",
                    "work" => "💼 Work",
                    _ => "📌 Other"
                };
                var categoryClass = task.Category switch
                {
                    "school" => "category-school",
                    "work" => "category-work",
                    _ => "category-other"
                };

                <li data-id="@task.Id" class="@(task.IsCompleted ? "completed" : "")">
                    <div class="task-info">
                        <span>@task.Title</span>
                        <div class="task-meta">
                            <span class="priority-badge priority-@task.Priority">@priorityText</span>
                            <span class="category-badge @categoryClass">@categoryText</span>
                            @if (task.DueDate.HasValue)
                            {
                                <span class="due-date @(isOverdue ? "overdue" : "")">
                                    Due: @task.DueDate.Value.ToString("yyyy-MM-dd")
                                </span>
                            }
                            @if (isDueToday)
                            {
                                <span class="today-tag">📅 Today</span>
                            }
                        </div>
                    </div>
                    <div class="button-container">
                        <button class="complete-btn">✔️</button>
                        <button class="delete-btn">🗑️</button>
                        <button class="edit-btn">✏️</button>
                    </div>
                </li>
            }
        </ul>

        <hr class="divider" />

        <div class="weekly-section">
            <h3>📅 Weekly Task Tracker</h3>
            <input type="week" id="weekPicker" />
            <div id="weeklyGrid" class="weekly-grid"></div>
        </div>

        <div class="chart-flex">
            <div class="dashboard-grid">
                <div class="stat-card">
                    <h3>📋 Total Tasks:</h3>
                    <p id="totalTasks">@Model.TotalTasks</p>
                </div>

                <div class="stat-card">
                    <h3>✅ Completed:</h3>
                    <p id="completedTasks">@Model.CompletedTasks</p>
                </div>

                <div class="stat-card">
                    <h3>⏳ Pending:</h3>
                    <p id="pendingTasks">@Model.PendingTasks</p>
                </div>

                <div class="stat-card">
                    <h3>📈 Completion Rate:</h3>
                    <p id="completionRate">@Model.CompletionRate.ToString("F1")%</p>

                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @Model.CompletionRate%"></div>
                    </div>
                </div>
            </div>

            <div class="chart-wrapper">
                <canvas id="statusChart" width="100" height="100"></canvas>
            </div>
        </div>
    </div>
</main>

<div id="messageModal" class="modal-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal-box">
        <h3 id="modalTitle">Notice</h3>
        <p id="modalMessage"></p>

        <button type="button" id="modalCloseBtn">
            OK
        </button>
    </div>
</div>

<script>
    function showModal(title, message) {
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalMessage').textContent = message;
    document.getElementById('messageModal').classList.remove('hidden');
    }

    function closeModal() {
    document.getElementById('messageModal').classList.add('hidden');
    }

    document.getElementById('modalCloseBtn')
    .addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
    closeModal();
    }
    });

    function getCsrfToken() {
    return document.querySelector('meta[name="csrf-token"]')?.content || "";
    }

    let chart;

    function getPriorityText(priority) {
    if (priority === "high") return "HIGH";
    if (priority === "medium") return "MED";
    return "LOW";
    }

    function escapeHtml(str = '') {
    return str.replace(/[&<>]/g, function (m) {
    if (m === '&') return '&amp;';
    if (m === '<') return '&lt;';
    if (m === '>') return '&gt;';
    return m;
    });
    }

    function refreshUI(data) {
    const taskList = document.getElementById('taskList');
    taskList.innerHTML = '';

    const categoryMap = { school: "🏫 School", work: "💼 Work", other: "📌 Other" };
    const categoryClassMap = { school: "category-school", work: "category-work", other: "category-other" };

    data.tasks.forEach(task => {
    const li = document.createElement('li');
    li.dataset.id = task.id;

    if (task.isCompleted) {
    li.classList.add('completed');
    }

    // Determine category values inside the loop context
    const categoryText = categoryMap[task.category] || "📌 Other";
    const categoryClass = categoryClassMap[task.category] || "category-other";

    const dueDateHtml = task.dueDate
    ? `<span class="due-date ${task.isOverdue ? 'overdue' : ''}">Due: ${task.dueDate}</span>`
    : "";

    const todayTagHtml = task.isDueToday ? '<span class="today-tag">📅 Today</span>' : "";

    li.innerHTML = `
    <div class="task-info">
    <span>${escapeHtml(task.title)}</span>
    <div class="task-meta">
    <span class="priority-badge priority-${task.priority}">${getPriorityText(task.priority)}</span>
    <span class="category-badge ${categoryClass}">${categoryText}</span>
    ${dueDateHtml}
    ${todayTagHtml}
    </div>
    </div>
    <div class="button-container">
    <button class="complete-btn">✔️</button>
    <button class="delete-btn">🗑️</button>
    <button class="edit-btn">✏️</button>
    </div>
    `;

    taskList.appendChild(li);
    });

    // Update your stat cards
    document.getElementById('totalTasks').innerText = data.stats.total;
    document.getElementById('completedTasks').innerText = data.stats.completed;
    document.getElementById('pendingTasks').innerText = data.stats.pending;

    const rate = data.stats.completionRate.toFixed(1);
    document.getElementById('completionRate').innerText = `${rate}%`;
    document.querySelector('.progress-fill').style.width = `${data.stats.completionRate}%`;

    // Redraw chart
    if (chart) {
    chart.destroy();
    }

    const ctx = document.getElementById('statusChart').getContext('2d');
    chart = new Chart(ctx, {
    type: 'pie',
    data: {
    labels: ['Completed', 'Pending'],
    datasets: [{
    data: [data.stats.completed, data.stats.pending],
    backgroundColor: ['#50c878', '#ef4444'],
    borderWidth: 0
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: {
    position: 'bottom',
    labels: { color: '#e5e7eb' }
    }
    }
    }
    });
    }

    async function callHandler(handler, payload) {
    try {
    const res = await fetch(`?handler=${handler}`, {
    method: 'POST',
    headers: {
    'Content-Type': 'application/json',
    'RequestVerificationToken': getCsrfToken()
    },
    body: JSON.stringify(payload)
    });

    if (res.ok) {
    const data = await res.json();
    refreshUI(data);
    return true;
    }

    if (res.status === 400) {
    try {
    const error = await res.json();

    showModal(
    "Validation Error",
    error.message || "Invalid input."
    );
    }
    catch {
    showModal(
    "Enter Task Title",
    "Task title cannot be empty."
    );
    }

    return false;
    }

    if (res.status === 404) {
    showModal(
    "Task Not Found",
    "The selected task could not be found."
    );

    return false;
    }

    showModal(
    "Server Error",
    "Something went wrong. Please try again."
    );

    return false;
    }
    catch {
    showModal(
    "Network Error",
    "Unable to connect to the server."
    );

    return false;
    }
    }

    document.getElementById('taskInput')
    .addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
    e.preventDefault();
    document.getElementById('addTaskBtn').click();
    }
    });

    document.getElementById('addTaskBtn')
    .addEventListener('click', async () => {

    const input = document.getElementById('taskInput');
    const prioritySelect = document.getElementById('prioritySelect');
    const dueDateInput = document.getElementById('dueDateInput');
    const category = document.getElementById('categorySelect').value;


    const title = input.value.trim();
    const priority = prioritySelect.value;
    const dueDate = dueDateInput.value;

    if (!title) {
    showModal(
    "Enter Task Title",
    "Task title cannot be empty."
    );
    return;
    }

    if (!dueDate) {
    showModal(
    "Enter Task Date",
    "Task date cannot be empty."
    );
    return;
    }

    const selectedDate = new Date(dueDate + "T00:00:00Z");
    const today = new Date();
    today.setUTCHours(0, 0, 0, 0); // today at UTC midnight

    if (selectedDate < today) {
    showModal("Past Task", "Tasks cannot be in the past. Please pick today or a future date.");
    return;
    }


    if (title.length > 100) {
    showModal(
    "Validation Error",
    "Task title cannot exceed 100 characters."
    );
    return;
    }

    const success = await callHandler('AddTask', {
    title,
    priority,
    dueDate,
    category
    });

    if (success) {
    input.value = '';
    dueDateInput.value = '';
    prioritySelect.value = 'low';
    document.getElementById('categorySelect').value = 'school';
    }
    });

    document.getElementById('taskList')
    .addEventListener('click', (e) => {

    const btn = e.target;
    const li = btn.closest('li');

    if (!li) {
    return;
    }

    const taskId = parseInt(li.dataset.id);

    if (btn.classList.contains('delete-btn')) {
    callHandler('DeleteTask', { taskId });
    }
    else if (btn.classList.contains('complete-btn')) {
    callHandler('ToggleTask', { taskId });
    }
    });

    window.addEventListener('load', () => {

    const ctx = document
    .getElementById('statusChart')
    .getContext('2d');

    const completed =
    parseInt(document.getElementById('completedTasks').innerText);

    const pending =
    parseInt(document.getElementById('pendingTasks').innerText);

    chart = new Chart(ctx, {
    type: 'pie',
    data: {
    labels: ['Completed', 'Pending'],
    datasets: [{
    data: [completed, pending],
    backgroundColor: [
    '#50c878',
    '#ef4444'
    ],
    borderWidth: 0
    }]
    },
    options: {
    responsive: true,
    plugins: {
    legend: {
    position: 'bottom',
    labels: {
    color: '#e5e7eb'
    }
    }
    }
    }
    });
    });

    
</script>