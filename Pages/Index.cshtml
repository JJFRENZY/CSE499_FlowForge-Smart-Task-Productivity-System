@page
@model IndexModel
@{
    ViewData["Title"] = "FlowForge";
}

<header class="main-header">
    <h1>FlowForge</h1>
    <p>Smart Task Productivity System</p>
</header>

<main>

    <section class="task-container">

        <h2>Add New Task</h2>

        <div class="task-form">

            <input type="text" id="taskInput" placeholder="Enter a task...">

            <button id="addTaskBtn">
                Add Task
            </button>

        </div>

        <ul id="taskList"></ul>

    </section>

</main>

<script src="~/js/site.js"></script>